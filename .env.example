## Database
# Neon: pooled URL for the Next.js app (often contains "-pooler" in the host).
# Migrations: `npm run db:migrate` uses Neon's HTTP migrator (see https://neon.tech/docs/guides/drizzle-migrations ).
# If 0012 failed halfway and you see "already exists", run: `npm run db:migrate:resolve-0012` then `npm run db:migrate`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
# Optional: direct URL for drizzle-kit migrate. If unset and DATABASE_URL is Neon pooler (-pooler host),
# `npm run db:migrate` derives the direct host automatically. Override here if needed.
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST_DIRECT:5432/DB?sslmode=require"
# ALLOW_POOLER_MIGRATE=1 — try migrate via pooler (usually fails on Neon).

## Auth (NextAuth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-strong-secret"

## Email (for confirmation + password reset)
# Mailgun API
EMAIL_FROM="yevgen@support.aiautomations.work"
MAILGUN_API_KEY="key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MAILGUN_DOMAIN="mg.your-domain.com"
MAILGUN_EU_REGION="false"

## Storage (signed scans → Vercel Blob)
# Dashboard: Vercel project → Storage → Blob → connect, or create token.
# The SDK reads BLOB_READ_WRITE_TOKEN (also aliased below for older samples).
BLOB_READ_WRITE_TOKEN=""

## App base URL (for internal server-side fetches)
APP_URL="http://localhost:3000"
